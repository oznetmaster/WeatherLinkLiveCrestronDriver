<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>SimpleWeatherClient</id>
    <version>1.0.2</version>
    <authors>Neil Colvin</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/oznetmaster/SimpleWeatherClient</projectUrl>
    <description>Dual-targeted OpenWeather client library with .NET Framework 4.7.2 and .NET 10 support, adapted from the original Banovvv/SimpleWeather project.</description>
    <copyright>Copyright © 2026 Neil Colvin</copyright>
    <tags>weather openweather forecast desktop net472 net10</tags>
    <repository type="git" url="https://github.com/oznetmaster/SimpleWeatherClient.git" commit="07b62a587143725dc9f31ae754bcf58f7b9b9bb9" />
    <dependencies>
      <group targetFramework="net10.0">
        <dependency id="Newtonsoft.Json" version="13.0.4" exclude="Build,Analyzers" />
        <dependency id="log4net" version="3.3.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETFramework4.7.2">
        <dependency id="Hafner.Compatibility.MetaPackage" version="1.9.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Bcl.AsyncInterfaces" version="10.0.8" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Bcl.HashCode" version="6.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Bcl.Memory" version="10.0.8" exclude="Build,Analyzers" />
        <dependency id="Newtonsoft.Json" version="13.0.4" exclude="Build,Analyzers" />
        <dependency id="System.Net.Http" version="4.3.4" exclude="Build,Analyzers" />
        <dependency id="System.Runtime.CompilerServices.Unsafe" version="6.1.2" exclude="Build,Analyzers" />
        <dependency id="log4net" version="3.3.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <frameworkAssemblies>
      <frameworkAssembly assemblyName="Microsoft.CSharp" targetFramework=".NETFramework4.7.2" />
      <frameworkAssembly assemblyName="System.Data.DataSetExtensions" targetFramework=".NETFramework4.7.2" />
      <frameworkAssembly assemblyName="System.IO" targetFramework=".NETFramework4.7.2" />
      <frameworkAssembly assemblyName="System.Net.Http" targetFramework=".NETFramework4.7.2" />
      <frameworkAssembly assemblyName="System.Runtime" targetFramework=".NETFramework4.7.2" />
      <frameworkAssembly assemblyName="System.Security.Cryptography.Algorithms" targetFramework=".NETFramework4.7.2" />
      <frameworkAssembly assemblyName="System.Security.Cryptography.Encoding" targetFramework=".NETFramework4.7.2" />
      <frameworkAssembly assemblyName="System.Security.Cryptography.Primitives" targetFramework=".NETFramework4.7.2" />
      <frameworkAssembly assemblyName="System.Security.Cryptography.X509Certificates" targetFramework=".NETFramework4.7.2" />
    </frameworkAssemblies>
  </metadata>
</package>